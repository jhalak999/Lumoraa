# ---- App ----
APP_NAME=Lumora
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# ---- Security ----
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-64-char-hex-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=20160
JWT_ALGORITHM=HS256

# ---- CORS ----
BACKEND_CORS_ORIGINS=http://localhost:5173

# ---- Database ----
DATABASE_URL=postgresql+psycopg://lumora:lumora@localhost:5432/lumora
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ---- Redis / Celery ----
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=false

# ---- LLM (OpenRouter) ----
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_RESEARCH_MODEL=perplexity/sonar
OPENROUTER_SCRIPT_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_SCENE_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_SEO_MODEL=openai/gpt-4o-mini
LLM_REQUEST_TIMEOUT_SECONDS=90
LLM_MAX_RETRIES=2

# ---- Image generation (ordered fallback chain, comma-separated) ----
STABILITY_API_KEY=
REPLICATE_API_TOKEN=
OPENAI_API_KEY=
IMAGE_PROVIDER_ORDER=stability,replicate,openai

# ---- Voice (ordered fallback chain) ----
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM
TTS_PROVIDER_ORDER=elevenlabs,gtts

# ---- Storage ----
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=./storage
PUBLIC_ASSET_BASE_URL=http://localhost:8000/static
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---- FFmpeg ----
FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe
VIDEO_DEFAULT_RESOLUTION=1080x1920
VIDEO_DEFAULT_FPS=30

# ---- Demo mode ----
DEMO_MODE=true
DEMO_MAX_VIDEO_DURATION_SECONDS=20
DEMO_MAX_SCENES=4
DEMO_VIDEO_RESOLUTION=720x1280
DEMO_VIDEO_FPS=15
DEMO_TTS_PROVIDER_ORDER=gtts,elevenlabs
DEMO_IMAGE_PROVIDER_ORDER=stability,replicate

# ---- Rate limiting ----
RATE_LIMIT_PER_MINUTE=60

# ---- Logging ----
LOG_LEVEL=INFO
LOG_JSON=false
